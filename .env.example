# Copy this file to `.env` (optional). Login is MANUAL (no credentials
# here). `.env` is gitignored.

# Default provider if --provider is not passed (facebook|whatsapp|linkedin)
PROVIDER=facebook

# Optional: persistent browser profile directory. Default = the provider's
# (./.fb-profile, ./.wa-profile, ./.li-profile). Keeps cookies + IndexedDB +
# cache between runs, so WhatsApp reuses its cached chats instead of resyncing.
# USER_DATA_DIR=./.fb-profile

# Optional: "1" = headless (NO window, DEFAULT), "0" = VISIBLE browser.
# The `--show` flag overrides this per command. Login always forces a window.
HEADLESS=1
