# Copie ce fichier en `.env`. La connexion est MANUELLE (pas d'identifiants ici).
# `.env` est gitignore.

# Optionnel : chemin du fichier de session sauvegardee (cookies)
FB_STATE_PATH=./fb-state.json

# Optionnel : "1" = headless (AUCUNE fenetre), "0" = navigateur VISIBLE.
# Le login force toujours une fenetre visible. Le post peut tourner en headless.
FB_HEADLESS=0
