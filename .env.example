# Copie ce fichier en `.env` et remplis tes identifiants Facebook.
# `.env` est gitignore — ne sera jamais committe.

FB_EMAIL=ton.email@example.com
FB_PASSWORD=ton_mot_de_passe

# Optionnel : chemin du fichier de session sauvegardee (cookies)
FB_STATE_PATH=./fb-state.json

# Optionnel : "1" = headless (AUCUNE fenetre), "0" = navigateur VISIBLE.
# Mets 0 pour voir ce que fait la lib et resoudre 2FA/captcha a la main.
FB_HEADLESS=0
